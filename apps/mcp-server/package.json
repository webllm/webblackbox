{
  "name": "@webblackbox/mcp-server",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "prebuild": "pnpm --filter @webblackbox/player-sdk build",
    "build": "tsup src/index.ts --format esm --clean",
    "prestart": "pnpm run build",
    "start": "node dist/index.js",
    "inspect": "pnpm run build && npx @modelcontextprotocol/inspector node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.21.1",
    "@webblackbox/mcp-core": "workspace:*",
    "@webblackbox/player-sdk": "workspace:*",
    "jszip": "^3.10.1",
    "zod": "^4.1.11"
  }
}
