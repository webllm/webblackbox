{
  "name": "@webblackbox/pipeline",
  "description": "Chunking, indexing, blob storage, and archive export pipeline for WebBlackbox recording sessions.",
  "version": "0.4.6",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "pipeline",
    "chunking",
    "indexing",
    "archive-export",
    "webblackbox",
    "session-replay"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webllm/webblackbox.git",
    "directory": "packages/pipeline"
  },
  "homepage": "https://github.com/webllm/webblackbox/tree/main/packages/pipeline",
  "bugs": {
    "url": "https://github.com/webllm/webblackbox/issues"
  },
  "author": "unadlib",
  "license": "MIT",
  "scripts": {
    "dev": "tsup src/index.ts --format esm --dts --watch --clean",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "bench": "tsx scripts/benchmark.ts"
  },
  "dependencies": {
    "@webblackbox/protocol": "workspace:*",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "fake-indexeddb": "^6.2.5"
  }
}
