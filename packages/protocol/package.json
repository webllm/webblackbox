{
  "name": "@webblackbox/protocol",
  "description": "Shared event types, schemas, IDs, and configuration defaults for the WebBlackbox ecosystem.",
  "version": "0.1.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "protocol",
    "schema",
    "zod",
    "events",
    "webblackbox",
    "session-replay"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webllm/webblackbox.git",
    "directory": "packages/protocol"
  },
  "homepage": "https://github.com/webllm/webblackbox/tree/main/packages/protocol",
  "bugs": {
    "url": "https://github.com/webllm/webblackbox/issues"
  },
  "author": "unadlib",
  "license": "MIT",
  "scripts": {
    "dev": "tsup src/index.ts --format esm --dts --watch --clean",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "zod": "^4.1.12"
  }
}
