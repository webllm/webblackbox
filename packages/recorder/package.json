{
  "name": "@webblackbox/recorder",
  "description": "Browser event recorder and normalization engine for WebBlackbox capture pipelines.",
  "version": "0.4.5",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "recorder",
    "browser-events",
    "cdp",
    "ring-buffer",
    "webblackbox",
    "session-replay"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webllm/webblackbox.git",
    "directory": "packages/recorder"
  },
  "homepage": "https://github.com/webllm/webblackbox/tree/main/packages/recorder",
  "bugs": {
    "url": "https://github.com/webllm/webblackbox/issues"
  },
  "author": "unadlib",
  "license": "MIT",
  "scripts": {
    "dev": "tsup src/index.ts --format esm --dts --watch --clean",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "bench": "tsx scripts/benchmark.ts"
  },
  "dependencies": {
    "@webblackbox/protocol": "workspace:*"
  }
}
