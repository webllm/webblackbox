{
  "name": "webblackbox",
  "description": "Browser-side lite capture SDK for recording, exporting, and embedding WebBlackbox sessions.",
  "version": "0.4.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./injected-hooks": {
      "types": "./dist/injected-hooks.d.ts",
      "import": "./dist/injected-hooks.js"
    },
    "./lite-capture-agent": {
      "types": "./dist/lite-capture-agent.d.ts",
      "import": "./dist/lite-capture-agent.js"
    },
    "./lite-materializer": {
      "types": "./dist/lite-materializer.d.ts",
      "import": "./dist/lite-materializer.js"
    },
    "./lite-sdk": {
      "types": "./dist/lite-sdk.d.ts",
      "import": "./dist/lite-sdk.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "webblackbox-sdk",
    "browser-sdk",
    "lite-capture",
    "session-replay",
    "webblackbox",
    "dom-capture"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webllm/webblackbox.git",
    "directory": "packages/webblackbox"
  },
  "homepage": "https://github.com/webllm/webblackbox/tree/main/packages/webblackbox",
  "bugs": {
    "url": "https://github.com/webllm/webblackbox/issues"
  },
  "author": "unadlib",
  "license": "MIT",
  "scripts": {
    "dev": "tsup src/index.ts src/injected-hooks.ts src/lite-capture-agent.ts src/lite-materializer.ts src/lite-sdk.ts src/types.ts --format esm --dts --watch --clean",
    "build": "tsup src/index.ts src/injected-hooks.ts src/lite-capture-agent.ts src/lite-materializer.ts src/lite-sdk.ts src/types.ts --format esm --dts --clean",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "jsdom": "^26.1.0"
  },
  "dependencies": {
    "@webblackbox/pipeline": "workspace:*",
    "@webblackbox/protocol": "workspace:*",
    "@webblackbox/recorder": "workspace:*",
    "@zumer/snapdom": "^2.0.2"
  }
}
