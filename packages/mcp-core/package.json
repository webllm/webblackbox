{
  "name": "@webblackbox/mcp-core",
  "description": "Small utility helpers and shared input schemas for WebBlackbox MCP integrations.",
  "version": "0.1.3",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "mcp",
    "utilities",
    "zod",
    "webblackbox",
    "tooling"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webllm/webblackbox.git",
    "directory": "packages/mcp-core"
  },
  "homepage": "https://github.com/webllm/webblackbox/tree/main/packages/mcp-core",
  "bugs": {
    "url": "https://github.com/webllm/webblackbox/issues"
  },
  "author": "unadlib",
  "license": "MIT",
  "scripts": {
    "dev": "tsup src/index.ts --format esm --dts --watch --clean",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^4.1.12"
  }
}
