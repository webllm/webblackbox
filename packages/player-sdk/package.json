{
  "name": "@webblackbox/player-sdk",
  "description": "Archive playback, querying, analysis, and code-generation SDK for WebBlackbox sessions.",
  "version": "0.4.4",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "player-sdk",
    "session-replay",
    "archive-analysis",
    "webblackbox",
    "playwright",
    "har"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webllm/webblackbox.git",
    "directory": "packages/player-sdk"
  },
  "homepage": "https://github.com/webllm/webblackbox/tree/main/packages/player-sdk",
  "bugs": {
    "url": "https://github.com/webllm/webblackbox/issues"
  },
  "author": "unadlib",
  "license": "MIT",
  "scripts": {
    "dev": "tsup src/index.ts --format esm --dts --watch --clean",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:pressure": "vitest run src/index.test.ts -t \"keeps large archive player pressure paths bounded\"",
    "test:coverage": "vitest run --coverage",
    "docs:api": "typedoc --options typedoc.json"
  },
  "dependencies": {
    "@webblackbox/protocol": "workspace:*",
    "jszip": "^3.10.1"
  }
}
